{
  "family": "wine-quality-app-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::330124996483:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::330124996483:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "wine-quality-container",
      "image": "330124996483.dkr.ecr.eu-north-1.amazonaws.com/wine-quality-container:latest",
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/wine-quality-container",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}